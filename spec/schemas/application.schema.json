{
  "$ref": "#/definitions/hap.application",
  "definitions": {
    "hap.application": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "hap.application"
        },
        "hap_version": {
          "type": "string",
          "default": "0.2.0-draft"
        },
        "application_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 64
        },
        "posting_ref": {
          "type": "object",
          "properties": {
            "posting_id": {
              "type": "string",
              "minLength": 8,
              "maxLength": 64
            },
            "posting_url": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": [
            "posting_id"
          ],
          "additionalProperties": false
        },
        "candidate": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "minLength": 2,
              "maxLength": 120
            },
            "human_contact": {
              "type": "string",
              "maxLength": 200
            },
            "agent_url": {
              "type": "string",
              "format": "uri"
            },
            "profile_evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "github_user",
                      "github_repo",
                      "github_commit",
                      "github_pr",
                      "talk",
                      "blog_post",
                      "paper",
                      "package",
                      "linkedin",
                      "personal_site",
                      "oss_maintainer",
                      "email_domain"
                    ]
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "note": {
                    "type": "string",
                    "maxLength": 200
                  },
                  "venue": {
                    "type": "string",
                    "maxLength": 80
                  },
                  "title": {
                    "type": "string",
                    "maxLength": 200
                  }
                },
                "required": [
                  "type",
                  "url"
                ],
                "additionalProperties": false
              },
              "maxItems": 6
            },
            "proof_of_control": {
              "type": "object",
              "properties": {
                "method": {
                  "type": "string",
                  "const": "github_gist"
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "required": [
                "method",
                "url"
              ],
              "additionalProperties": false
            }
          },
          "required": [
            "name",
            "human_contact"
          ],
          "additionalProperties": false
        },
        "responses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question_id": {
                "type": "string",
                "maxLength": 40
              },
              "answer": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "maxLength": 4000
                  },
                  "evidence": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": [
                            "github_user",
                            "github_repo",
                            "github_commit",
                            "github_pr",
                            "talk",
                            "blog_post",
                            "paper",
                            "package",
                            "linkedin",
                            "personal_site",
                            "oss_maintainer",
                            "email_domain"
                          ]
                        },
                        "url": {
                          "type": "string",
                          "format": "uri"
                        },
                        "note": {
                          "type": "string",
                          "maxLength": 200
                        },
                        "venue": {
                          "type": "string",
                          "maxLength": 80
                        },
                        "title": {
                          "type": "string",
                          "maxLength": 200
                        }
                      },
                      "required": [
                        "type",
                        "url"
                      ],
                      "additionalProperties": false
                    },
                    "maxItems": 8
                  },
                  "confidence": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high"
                    ]
                  },
                  "decline_reason": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "private",
                          "not_applicable",
                          "no_evidence",
                          "out_of_scope"
                        ]
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "text",
                  "evidence",
                  "confidence"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "question_id",
              "answer"
            ],
            "additionalProperties": false
          },
          "maxItems": 15
        },
        "extra_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "github_user",
                  "github_repo",
                  "github_commit",
                  "github_pr",
                  "talk",
                  "blog_post",
                  "paper",
                  "package",
                  "linkedin",
                  "personal_site",
                  "oss_maintainer",
                  "email_domain"
                ]
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "note": {
                "type": "string",
                "maxLength": 200
              },
              "venue": {
                "type": "string",
                "maxLength": 80
              },
              "title": {
                "type": "string",
                "maxLength": 200
              }
            },
            "required": [
              "type",
              "url"
            ],
            "additionalProperties": false
          },
          "maxItems": 8
        },
        "self_assessment": {
          "type": "object",
          "properties": {
            "fit": {
              "type": "string",
              "enum": [
                "strong",
                "plausible",
                "stretch"
              ]
            },
            "note": {
              "type": "string",
              "maxLength": 500
            }
          },
          "required": [
            "fit"
          ],
          "additionalProperties": false
        },
        "disclosure": {
          "type": "object",
          "properties": {
            "contact_release": {
              "type": "string",
              "enum": [
                "on_submit",
                "on_employer_interest"
              ],
              "default": "on_submit"
            },
            "public": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "kind",
        "application_id",
        "posting_ref",
        "candidate",
        "responses",
        "disclosure"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
