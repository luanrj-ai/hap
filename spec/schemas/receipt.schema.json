{
  "$ref": "#/definitions/hap.receipt",
  "definitions": {
    "hap.receipt": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "hap.receipt"
        },
        "hap_version": {
          "type": "string",
          "default": "0.2.0-draft"
        },
        "application_id": {
          "type": "string",
          "minLength": 8,
          "maxLength": 64
        },
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "received",
            "rejected",
            "duplicate"
          ]
        },
        "next": {
          "type": "string",
          "enum": [
            "human_will_contact",
            "agent_followup_possible",
            "none"
          ],
          "default": "none"
        },
        "note": {
          "type": "string",
          "maxLength": 200
        }
      },
      "required": [
        "kind",
        "application_id",
        "received_at",
        "status"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
