# Local dev — SQLite file (zero setup)
DATABASE_URL="file:./resumetruth.db"

# For prod, switch provider in prisma/schema.prisma to "postgresql" and use:
# DATABASE_URL="postgresql://user:password@localhost:5432/resumetruth?schema=public"

# --- LLM provider (optional; pure rule engine works without any LLM) ---
# Set EITHER Anthropic OR OpenAI block. If both set, OpenAI wins.

# Anthropic Claude (recommended for production: native prompt caching, EU AI Act friendly)
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL=""

# OpenAI-compatible endpoint (also covers GPT-via-proxy aggregators like One-API, uyilink, etc.)
# WARNING: non-OpenAI/non-Anthropic endpoints mean your prompts (incl. resume text)
# pass through their servers. Do NOT use for real candidate data without DPA.
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-5.5"

# --- External verifier ---
# Optional GitHub personal access token. Without it the GitHub API caps you at
# 60 requests / hour (rate-limited error after that). With a token: 5000/hour.
# Create at: https://github.com/settings/tokens — read-only "public_repo" scope is enough.
GITHUB_TOKEN=""
